# =====================================================================
# Rate My Husky — environment variables
# Copy this file to .env.local and fill in values from the Firebase console.
# Do not commit .env.local. All secrets must stay out of git.
# =====================================================================

# ---- Firebase Web SDK (safe to expose to the browser) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin SDK (server-only — never expose) ----
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private_key from your service account JSON.
# Wrap in quotes and keep the literal \n sequences — firebaseAdmin.ts un-escapes them.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
